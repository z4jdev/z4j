{
  "name": "@z4j/dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "z4j brain dashboard - TanStack Router + React 19 + shadcn/ui",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc -b --noEmit",
    "build:demo": "node scripts/build-demo.mjs",
    "preview": "vite preview",
    "preview:demo": "vite preview --outDir dist-demo --port 4173",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint . --ext ts,tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "openapi:fetch": "node scripts/fetch-openapi-snapshot.mjs",
    "openapi:gen": "openapi-typescript src/lib/openapi-snapshot.json -o src/lib/openapi-types.gen.ts --immutable",
    "openapi:check": "openapi-typescript src/lib/openapi-snapshot.json -o /tmp/_openapi-types.gen.ts --immutable && node --input-type=module -e \"import fs from 'node:fs'; const a = fs.readFileSync('src/lib/openapi-types.gen.ts','utf8'); const b = fs.readFileSync('/tmp/_openapi-types.gen.ts','utf8'); if (a !== b) { console.error('OpenAPI -> TS drift detected. Run \\\"pnpm openapi:gen\\\" and commit.'); process.exit(1); }\" && pnpm typecheck",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-router": "^1.169.2",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.14.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.75.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query-devtools": "^5.100.10",
    "@tanstack/router-plugin": "^1.167.35",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.3.0",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.14",
    "prettier": "^3.8.3",
    "rolldown": "1.0.1",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.15.0"
  },
  "pnpm": {
    "//": [
      "Supply-chain hardening - keep ``onlyBuiltDependencies`` as",
      "an empty allowlist so NO transitive package may run a build",
      "/install/postinstall script. The .npmrc also sets",
      "``ignore-scripts=true`` and ``enable-pre-post-scripts=false``",
      "as defense in depth. If a future dep legitimately needs a",
      "build step (rare for an SPA), add it here EXPLICITLY after",
      "auditing the script."
    ],
    "onlyBuiltDependencies": [],
    "auditConfig": {
      "ignoreCves": []
    }
  }
}
