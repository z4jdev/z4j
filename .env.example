# ----------------------------------------------------------------------
# z4j - environment configuration
#
# Copy this file to `.env` and fill in the values before running
# `docker compose up`. `.env` is gitignored so your secrets stay local.
#
# Generate fresh secrets with:
#   openssl rand -hex 48
# or:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# ----------------------------------------------------------------------


# ======================================================================
# Required in production
# ======================================================================

# HMAC signing keys (>= 32 bytes each). If unset, the brain auto-generates
# on first boot and persists to /data/secret.env. For fresh deployments
# on evaluation / homelab machines you can leave these empty; for any
# multi-host or redeploy-from-scratch scenario, set them explicitly.
Z4J_SECRET=
Z4J_SESSION_SECRET=


# ======================================================================
# Environment - set to "dev" during local dev, leave as "production"
# (default) otherwise. In production the brain refuses to start unless
# Z4J_ALLOWED_HOSTS is set and Z4J_PUBLIC_URL uses https://.
# ======================================================================

Z4J_ENVIRONMENT=production


# ======================================================================
# Public URL + allowed hosts
# (REQUIRED when Z4J_ENVIRONMENT=production)
# ======================================================================

# Externally reachable URL of the brain. Used to build first-boot
# setup links and password-reset emails. Must be https:// in prod.
Z4J_PUBLIC_URL=https://z4j.example.com

# JSON array of hostnames the brain will accept in the Host header.
# Prevents host-header injection.
Z4J_ALLOWED_HOSTS=["z4j.example.com"]


# ======================================================================
# PostgreSQL mode (only needed when using docker-compose.postgres.yml)
# ======================================================================

# Postgres service credentials. The docker-compose.postgres.yml file
# injects these into BOTH the postgres service init AND the brain's
# Z4J_DATABASE_URL.
POSTGRES_USER=z4j
POSTGRES_PASSWORD=
POSTGRES_DB=z4j


# ======================================================================
# Caddy reverse proxy (only needed when using docker-compose.caddy.yml)
# ======================================================================

# Domain name Caddy will provision a Let's Encrypt certificate for.
Z4J_DOMAIN=z4j.example.com

# Email address submitted to Let's Encrypt for cert-expiry notices.
Z4J_ACME_EMAIL=you@example.com


# ======================================================================
# Optional: bootstrap the first admin automatically
# ======================================================================

# When BOTH are set AND the users table is empty, the brain provisions
# the admin user at boot and skips the printed setup-URL step. Handy
# for CI / Terraform / headless installs. Leave blank for interactive
# first-boot.
Z4J_BOOTSTRAP_ADMIN_EMAIL=
Z4J_BOOTSTRAP_ADMIN_PASSWORD=


# ======================================================================
# Optional: tune retention + rate limits
# ======================================================================

# Z4J_EVENT_RETENTION_DAYS=30           # raw event lifetime
# Z4J_AUDIT_RETENTION_DAYS=90           # audit-log lifetime
# Z4J_COMMAND_TIMEOUT_SECONDS=60        # pending-command timeout
# Z4J_AGENT_OFFLINE_TIMEOUT_SECONDS=30  # heartbeat-miss threshold
# Z4J_RATELIMIT_COMMANDS_PER_MINUTE=100 # per-project command cap
# Z4J_RATELIMIT_EVENTS_PER_SECOND=10000 # per-project event cap


# ======================================================================
# Docker image override (useful for pinning to a specific release)
# ======================================================================

# Z4J_IMAGE=z4jdev/z4j:1.0.1
# Z4J_BRAIN_IMAGE=z4jdev/z4j:1.0.1
